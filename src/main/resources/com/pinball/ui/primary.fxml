<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pinball.ui.PrimaryController" style="-fx-background-color: #1e1e2e;">
    
    <center>
        <StackPane fx:id="canvasContainer" />
    </center>

    <right>
        <VBox prefWidth="200" spacing="15" style="-fx-background-color: #313244; -fx-padding: 20;">
            <Label fx:id="scoreLabel" text="Score: 0" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        </VBox>
    </right>

</BorderPane>